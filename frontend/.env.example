# ============================================================================
# Frontend Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in your actual values
# ============================================================================

# API Configuration
REACT_APP_API_URL=http://localhost:5000

# ============================================================================
# Environment-Specific Values:
# ============================================================================
# Development: http://localhost:5000
# Production: https://api.yourdomain.com
# ============================================================================

# ============================================================================
# Notes:
# ============================================================================
# 1. All React environment variables must start with REACT_APP_
# 2. Changes to .env require restarting the development server
# 3. These values are embedded in the build at compile time
# 4. Never store sensitive data (API keys, secrets) in frontend .env
# ============================================================================
